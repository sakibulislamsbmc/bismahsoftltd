{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile photo"
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp when the user was created"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role"
        }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "UserService": {
      "title": "User Service",
      "description": "A service purchased by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Pending"] },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "status", "date", "userId"]
    },
    "UserCourse": {
      "title": "User Course",
      "description": "A course enrolled by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "progress": { "type": "number" },
        "nextLesson": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "progress", "nextLesson", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A payment transaction made by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "gateway": { "type": "string", "enum": ["bKash", "Nagad", "Rocket", "Stripe", "PayPal", "Bank Transfer"] },
        "status": { "type": "string", "enum": ["Success", "Pending", "Failed"] },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "transactionId": { "type": "string" }
      },
      "required": ["id", "date", "amount", "gateway", "status", "description", "userId", "transactionId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/users/{userId}/services/{serviceId}": {
      "schema": {
        "$ref": "#/entities/UserService"
      },
      "description": "Stores services purchased by the user"
    },
    "/users/{userId}/courses/{courseId}": {
      "schema": {
        "$ref": "#/entities/UserCourse"
      },
      "description": "Stores courses enrolled by the user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores payment transactions made by the user"
    }
  }
}
